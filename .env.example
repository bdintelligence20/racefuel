# Strava API Credentials
# Get these from https://www.strava.com/settings/api

VITE_STRAVA_CLIENT_ID=your_client_id_here
VITE_STRAVA_CLIENT_SECRET=your_client_secret_here

# Optional: Override redirect URI (defaults to window.location.origin)
# VITE_STRAVA_REDIRECT_URI=http://localhost:5173

# Mapbox Token
# Get your token from https://account.mapbox.com/
# Free tier: 50,000 map loads/month
VITE_MAPBOX_TOKEN=your_mapbox_token_here
